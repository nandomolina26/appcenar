<div class="d-flex justify-content-between align-items-center mb-4">
  <h5 class="text-danger mb-0"><i class="bi bi-geo-alt"></i> Mis direcciones</h5>
  <a href="/client/addresses/create" class="btn btn-danger btn-sm">
    <i class="bi bi-plus-circle"></i> Agregar
  </a>
</div>

{{#if showCreate}}
  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <h6 class="fw-bold mb-3">Nueva dirección</h6>
      <form action="/client/addresses/create" method="POST">
        <div class="mb-3">
          <label class="form-label">Nombre</label>
          <input type="text" name="nombre" class="form-control" placeholder="Ej: Casa, Oficina" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Descripción</label>
          <input type="text" name="descripcion" class="form-control" placeholder="Ej: Calle 5, Apt 3B" required>
        </div>
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-danger">Guardar</button>
          <a href="/client/addresses" class="btn btn-outline-secondary">Cancelar</a>
        </div>
      </form>
    </div>
  </div>
{{/if}}

{{#if editAddress}}
  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <h6 class="fw-bold mb-3">Editar dirección</h6>
      <form action="/client/addresses/edit/{{editAddress._id}}" method="POST">
        <div class="mb-3">
          <label class="form-label">Nombre</label>
          <input type="text" name="nombre" class="form-control" value="{{editAddress.nombre}}" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Descripción</label>
          <input type="text" name="descripcion" class="form-control" value="{{editAddress.descripcion}}" required>
        </div>
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-danger">Actualizar</button>
          <a href="/client/addresses" class="btn btn-outline-secondary">Cancelar</a>
        </div>
      </form>
    </div>
  </div>
{{/if}}

{{#if deleteAddress}}
  <div class="card border-danger shadow-sm mb-4">
    <div class="card-body text-center">
      <p class="fw-bold">¿Está seguro que desea eliminar esta dirección?</p>
      <p class="text-muted">{{deleteAddress.nombre}} - {{deleteAddress.descripcion}}</p>
      <div class="d-flex justify-content-center gap-3">
        <form action="/client/addresses/delete/{{deleteAddress._id}}" method="POST">
          <button type="submit" class="btn btn-danger">Aceptar</button>
        </form>
        <a href="/client/addresses" class="btn btn-outline-secondary">Cancelar</a>
      </div>
    </div>
  </div>
{{/if}}

<div class="list-group">
  {{#each addresses}}
    <div class="list-group-item py-3">
      <div class="d-flex align-items-center gap-3">
        <i class="bi bi-geo-alt-fill text-danger fs-4"></i>
        <div class="flex-grow-1">
          <p class="mb-0 fw-semibold">{{this.nombre}}</p>
          <small class="text-muted">{{this.descripcion}}</small>
        </div>
        <div class="d-flex gap-2">
          <a href="/client/addresses/edit/{{this._id}}" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-pencil"></i>
          </a>
          <a href="/client/addresses/delete/{{this._id}}" class="btn btn-sm btn-outline-danger">
            <i class="bi bi-trash"></i>
          </a>
        </div>
      </div>
    </div>
  {{else}}
    <div class="list-group-item text-center text-muted py-5">
      <i class="bi bi-geo-alt fs-1"></i>
      <p class="mt-2">No tienes direcciones registradas.</p>
    </div>
  {{/each}}
</div>