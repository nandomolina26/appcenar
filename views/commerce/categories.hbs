<div class="d-flex justify-content-between align-items-center mb-4">
  <h5 class="text-danger mb-0"><i class="bi bi-tags"></i> Categorías</h5>
  <a href="/commerce/categories/create" class="btn btn-danger btn-sm">
    <i class="bi bi-plus-circle"></i> Nueva categoría
  </a>
</div>

{{#if showCreate}}
  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <h6 class="fw-bold mb-3">Nueva categoría</h6>
      <form action="/commerce/categories/create" method="POST">
        <div class="mb-3">
          <label class="form-label">Nombre</label>
          <input type="text" name="nombre" class="form-control" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Descripción</label>
          <input type="text" name="descripcion" class="form-control" required>
        </div>
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-danger">Crear</button>
          <a href="/commerce/categories" class="btn btn-outline-secondary">Cancelar</a>
        </div>
      </form>
    </div>
  </div>
{{/if}}

{{#if editCategory}}
  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <h6 class="fw-bold mb-3">Editar categoría</h6>
      <form action="/commerce/categories/edit/{{editCategory._id}}" method="POST">
        <div class="mb-3">
          <label class="form-label">Nombre</label>
          <input type="text" name="nombre" class="form-control" value="{{editCategory.nombre}}" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Descripción</label>
          <input type="text" name="descripcion" class="form-control" value="{{editCategory.descripcion}}" required>
        </div>
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-danger">Actualizar</button>
          <a href="/commerce/categories" class="btn btn-outline-secondary">Cancelar</a>
        </div>
      </form>
    </div>
  </div>
{{/if}}

{{#if deleteCategory}}
  <div class="card border-danger shadow-sm mb-4">
    <div class="card-body text-center">
      <p class="fw-bold">¿Está seguro que desea eliminar esta categoría?</p>
      <p class="text-muted">{{deleteCategory.nombre}}</p>
      <div class="d-flex justify-content-center gap-3">
        <form action="/commerce/categories/delete/{{deleteCategory._id}}" method="POST">
          <button type="submit" class="btn btn-danger">Aceptar</button>
        </form>
        <a href="/commerce/categories" class="btn btn-outline-secondary">Cancelar</a>
      </div>
    </div>
  </div>
{{/if}}

<div class="table-responsive">
  <table class="table table-hover align-middle">
    <thead class="table-light">
      <tr>
        <th>Nombre</th>
        <th>Descripción</th>
        <th>Productos</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      {{#each categories}}
        <tr>
          <td class="fw-semibold">{{this.nombre}}</td>
          <td class="text-muted">{{this.descripcion}}</td>
          <td><span class="badge bg-secondary">{{this.productCount}}</span></td>
          <td>
            <div class="d-flex gap-2">
              <a href="/commerce/categories/edit/{{this._id}}" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-pencil"></i>
              </a>
              <a href="/commerce/categories/delete/{{this._id}}" class="btn btn-sm btn-outline-danger">
                <i class="bi bi-trash"></i>
              </a>
            </div>
          </td>
        </tr>
      {{else}}
        <tr>
          <td colspan="4" class="text-center text-muted py-4">No hay categorías creadas.</td>
        </tr>
      {{/each}}
    </tbody>
  </table>
</div>