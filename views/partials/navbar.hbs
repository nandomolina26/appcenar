        {{/if}}

        {{#if (eq user.role "administrador")}}
          <li class="nav-item"><a class="nav-link" href="/admin/home"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/clients"><i class="bi bi-people"></i> Clientes</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/deliveries"><i class="bi bi-bicycle"></i> Deliveries</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/commerces"><i class="bi bi-shop"></i> Comercios</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/commerce-types"><i class="bi bi-grid"></i> Tipos</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/admins"><i class="bi bi-shield-person"></i> Admins</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/config"><i class="bi bi-gear"></i> Config</a></li>
        {{/if}}

      </ul>
      <ul class="navbar-nav ms-auto align-items-center">
        <li class="nav-item">
          <span class="nav-link text-white">
            {{#if user.foto}}
              <img src="/uploads/profiles/{{user.foto}}" class="rounded-circle me-1" width="28" height="28" style="object-fit:cover">
            {{else}}
              <i class="bi bi-person-circle"></i>
            {{/if}}
            {{user.nombre}}
          </span>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/auth/logout"><i class="bi bi-box-arrow-right"></i> Salir</a>
        </li>
      </ul>
