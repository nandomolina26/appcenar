          <li class="nav-item"><a class="nav-link" href="/client/profile"><i class="bi bi-person"></i> Mi perfil</a></li>
          <li class="nav-item"><a class="nav-link" href="/client/orders"><i class="bi bi-bag"></i> Mis pedidos</a></li>
          <li class="nav-item"><a class="nav-link" href="/client/addresses"><i class="bi bi-geo-alt"></i> Mis direcciones</a></li>
          <li class="nav-item"><a class="nav-link" href="/client/favorites"><i class="bi bi-heart"></i> Mis favoritos</a></li>
        {{/if}}

        {{#if (eq user.role "delivery")}}
          <li class="nav-item"><a class="nav-link" href="/delivery/home"><i class="bi bi-house"></i> Home</a></li>
          <li class="nav-item"><a class="nav-link" href="/delivery/profile"><i class="bi bi-person"></i> Mi perfil</a></li>
        {{/if}}

        {{#if (eq user.role "comercio")}}
          <li class="nav-item"><a class="nav-link" href="/commerce/home"><i class="bi bi-house"></i> Home</a></li>
          <li class="nav-item"><a class="nav-link" href="/commerce/profile"><i class="bi bi-person"></i> Mi perfil</a></li>
          <li class="nav-item"><a class="nav-link" href="/commerce/categories"><i class="bi bi-tags"></i> Categorías</a></li>
