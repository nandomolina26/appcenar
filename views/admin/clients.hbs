<h5 class="text-danger mb-4"><i class="bi bi-people"></i> Clientes</h5>

<div class="table-responsive">
  <table class="table table-hover align-middle">
    <thead class="table-light">
      <tr>
        <th>Nombre</th>
        <th>Usuario</th>
        <th>Teléfono</th>
        <th>Correo</th>
        <th>Pedidos</th>
        <th>Estado</th>
        <th>Acción</th>
      </tr>
    </thead>
    <tbody>
      {{#each clients}}
        <tr>
          <td>{{this.nombre}} {{this.apellido}}</td>
          <td class="text-muted">{{this.usuario}}</td>
          <td>{{this.telefono}}</td>
          <td>{{this.correo}}</td>
          <td><span class="badge bg-secondary">{{this.orderCount}}</span></td>
          <td>
            <span class="badge bg-{{#if this.activo}}success{{else}}danger{{/if}}">
              {{#if this.activo}}Activo{{else}}Inactivo{{/if}}
            </span>
          </td>
          <td>
            <form action="/admin/clients/{{this._id}}/toggle" method="POST">
              <button type="submit" class="btn btn-sm {{#if this.activo}}btn-outline-danger{{else}}btn-outline-success{{/if}}">
                {{#if this.activo}}Inactivar{{else}}Activar{{/if}}
              </button>
            </form>
          </td>
        </tr>
      {{else}}
        <tr>
          <td colspan="7" class="text-center text-muted py-4">No hay clientes registrados.</td>
        </tr>
      {{/each}}
    </tbody>
  </table>
</div>