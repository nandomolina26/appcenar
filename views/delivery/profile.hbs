<div class="row justify-content-center">
  <div class="col-md-6">
    <h5 class="text-danger mb-4"><i class="bi bi-person-circle"></i> Mi perfil</h5>
    <div class="card shadow-sm border-0">
      <div class="card-body p-4">
        <div class="text-center mb-4">
          {{#if profile.foto}}
            <img src="/uploads/profiles/{{profile.foto}}"
              class="rounded-circle mb-2" width="90" height="90" style="object-fit:cover">
          {{else}}
            <div class="bg-secondary rounded-circle d-flex align-items-center justify-content-center mx-auto mb-2"
              style="width:90px;height:90px">
              <i class="bi bi-person text-white" style="font-size:2.5rem"></i>
            </div>
          {{/if}}
        </div>
        <form action="/delivery/profile" method="POST" enctype="multipart/form-data">
          <div class="mb-3">
            <label class="form-label">Nombre</label>
            <input type="text" name="nombre" class="form-control" value="{{profile.nombre}}" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Apellido</label>
            <input type="text" name="apellido" class="form-control" value="{{profile.apellido}}" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Teléfono</label>
            <input type="text" name="telefono" class="form-control" value="{{profile.telefono}}" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Foto de perfil</label>
            <input type="file" name="foto" class="form-control" accept="image/*">
          </div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger">Guardar</button>
            <a href="/delivery/home" class="btn btn-outline-secondary">Cancelar</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>