<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card shadow-sm mt-4">
      <div class="card-body p-4">
        <h5 class="mb-4 text-danger"><i class="bi bi-person-plus"></i> Crear cuenta</h5>
        <form action="/auth/register" method="POST" enctype="multipart/form-data">
          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label">Nombre</label>
              <input type="text" name="nombre" class="form-control" value="{{body.nombre}}" required>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Apellido</label>
              <input type="text" name="apellido" class="form-control" value="{{body.apellido}}" required>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Teléfono</label>
            <input type="text" name="telefono" class="form-control" value="{{body.telefono}}" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Correo</label>
            <input type="email" name="correo" class="form-control" value="{{body.correo}}" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Nombre de usuario</label>
            <input type="text" name="usuario" class="form-control" value="{{body.usuario}}" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Foto de perfil</label>
            <input type="file" name="foto" class="form-control" accept="image/*">
          </div>
          <div class="mb-3">
            <label class="form-label">Rol</label>
            <select name="role" class="form-select" required>
              <option value="">Selecciona un rol</option>
              <option value="cliente" {{#if (eq body.role "cliente")}}selected{{/if}}>Cliente</option>
              <option value="delivery" {{#if (eq body.role "delivery")}}selected{{/if}}>Delivery</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Contraseña</label>
            <input type="password" name="password" class="form-control" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Confirmar contraseña</label>
            <input type="password" name="confirmarPassword" class="form-control" required>
          </div>
          <button type="submit" class="btn btn-danger w-100">Crear cuenta</button>
          <a href="/auth/login" class="btn btn-link w-100 text-center mt-2">Volver al login</a>
        </form>
      </div>
    </div>
  </div>
</div>