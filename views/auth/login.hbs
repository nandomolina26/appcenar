<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card shadow-sm mt-5">
      <div class="card-body p-4">
        <h4 class="text-center mb-4 text-danger">
          <i class="bi bi-bag-heart-fill"></i> AppCenar
        </h4>
        <form action="/auth/login" method="POST">
          <div class="mb-3">
            <label class="form-label">Usuario o correo</label>
            <input type="text" name="usuario" class="form-control" placeholder="Tu usuario o correo" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Contraseña</label>
            <input type="password" name="password" class="form-control" placeholder="Tu contraseña" required>
          </div>
          <button type="submit" class="btn btn-danger w-100">Iniciar sesión</button>
        </form>
        <hr>
        <div class="d-grid gap-2">
          <a href="/auth/register" class="btn btn-outline-secondary">
            <i class="bi bi-person-plus"></i> Registrarse como cliente o delivery
          </a>
          <a href="/auth/register-commerce" class="btn btn-outline-secondary">
            <i class="bi bi-shop"></i> Registrarse como comercio
          </a>
          <a href="/auth/forgot-password" class="btn btn-link text-danger text-center">
            ¿Olvidaste tu contraseña?
          </a>
        </div>
      </div>
    </div>
  </div>
</div>