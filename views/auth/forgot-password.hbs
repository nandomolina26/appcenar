<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card shadow-sm mt-5">
      <div class="card-body p-4">
        <h5 class="mb-4 text-danger"><i class="bi bi-key"></i> Restablecer contraseña</h5>
        <form action="/auth/forgot-password" method="POST">
          <div class="mb-3">
            <label class="form-label">Usuario o correo</label>
            <input type="text" name="usuario" class="form-control" placeholder="Tu usuario o correo" required>
          </div>
          <button type="submit" class="btn btn-danger w-100">Enviar enlace</button>
          <a href="/auth/login" class="btn btn-link w-100 text-center mt-2">Volver al login</a>
        </form>
      </div>
    </div>
  </div>
</div>